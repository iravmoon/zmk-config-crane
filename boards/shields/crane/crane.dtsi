#include <dt-bindings/zmk/matrix_transform.h> 

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <8>;
//       | SW5  | SW8  | SW11 | SW14 | SW17 |       | SW17 | SW14 | SW11 | SW8  | SW5  |
// | SW2 | SW4  | SW7  | SW10 | SW13 | SW16 |       | SW16 | SW13 | SW10 | SW7  | SW4  | SW2 |
// | SW1 | SW3  | SW6  | SW9  | SW12 | SW15 |       | SW15 | SW12 | SW9  | SW6  | SW3  | SW1 |
//       | SW19 | SW20 | SW21 | SW22 | SW18 |       | SW18 | SW22 | SW21 | SW20 | SW19 |
        map = <
        RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)        RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)        RC(5,6) RC(5,7) RC(5,8) RC(5,9) RC(5,10) RC(5,11)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)        RC(6,6) RC(6,7) RC(6,8) RC(6,9) RC(6,10) RC(6,11)
        RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)        RC(7,6) RC(7,7) RC(7,8) RC(7,9) RC(7,10)
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan0>;
        transform = <&default_transform>;
    };
};